# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Compiled operator and CLI binaries
bin/
/kubectl-fchaos
/kubectl-fchaos-*
/chaos-operator

# Test binary, built with `go test -c`
*.test

# Rich error detection files
*.out

# Coverage output, generated with `go test -coverprofile`
*.coverprofile

# Claude Code local files
.claude/

# Editor-specific files
.idea/
.vscode/
.DS_Store

# macOS metadata
**/.DS_Store

# React build output copied into the Go embed directory — regenerated by make build-ui
cmd/ui-server/dist/*
!cmd/ui-server/dist/.gitkeep

# ui-server built binary (root level only, not the cmd/ui-server/ source dir)
/ui-server